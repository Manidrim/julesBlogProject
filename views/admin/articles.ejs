<%- include('../partials/header') %>

<h1>Manage Articles</h1>
<a href="/admin/articles/new" class="btn btn-success mb-3">Create New Article</a>

<table class="table">
  <thead>
    <tr>
      <th>Title</th>
      <th>Status</th>
      <th>Created At</th>
      <th>Actions</th>
    </tr>
  </thead>
  <tbody>
    <% articles.forEach(article => { %>
      <tr>
        <td><%= article.title %></td>
        <td><%= article.published ? 'Published' : 'Draft' %></td>
        <td><%= article.createdAt.toDateString() %></td>
        <td>
          <a href="/admin/articles/<%= article.id %>/edit" class="btn btn-primary btn-sm">Edit</a>
          <form action="/admin/articles/<%= article.id %>?_method=DELETE" method="POST" class="d-inline">
            <button type="submit" class="btn btn-danger btn-sm">Delete</button>
          </form>
        </td>
      </tr>
    <% }) %>
  </tbody>
</table>

<a href="/admin" class="btn btn-secondary mt-3">Back to Dashboard</a>

<%- include('../partials/footer') %>
